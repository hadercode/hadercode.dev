---
interface Props {
  type?: string; // e.g. "text", "email", "textarea"
  id: string;
  name: string;
  label: string;
  required?: boolean;
  rows?: number; // Only used when type is "textarea"
}

const {
  type = "text",
  id,
  name,
  label,
  required = false,
  rows = 4,
} = Astro.props;
const isTextarea = type === "textarea";
---

<div class="form-group">
  {
    isTextarea ? (
      <textarea
        id={id}
        name={name}
        required={required}
        rows={rows}
        placeholder=" "
        class="form-input form-textarea"
      />
    ) : (
      <input
        type={type as any}
        id={id}
        name={name}
        required={required}
        placeholder=" "
        class="form-input"
      />
    )
  }
  <label for={id} class="form-label">{label}</label>
  <span class="input-line"></span>
</div>

<style>
  .form-group {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .form-input {
    background: transparent;
    border: none;
    padding: 0.75rem 0;
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--text-primary);
    outline: none;
    z-index: 1;
  }

  .form-textarea {
    resize: none;
  }

  .form-label {
    position: absolute;
    left: 0;
    top: 0.75rem;
    font-size: 1.1rem;
    color: var(--text-secondary);
    transition:
      transform 0.3s var(--ease-out-expo),
      color 0.3s ease,
      font-size 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }

  .form-input:focus ~ .form-label,
  .form-input:not(:placeholder-shown) ~ .form-label {
    transform: translateY(-1.75rem);
    font-size: 0.8rem;
    color: var(--accent-primary);
    font-family: var(--font-mono);
  }

  .input-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.1);
    transition: background-color 0.3s ease;
  }

  .input-line::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .form-input:focus ~ .input-line::after {
    transform: scaleX(1);
  }

  .form-input:focus ~ .input-line {
    background-color: transparent;
  }
</style>
