---
import Card from "./Card.astro";

interface Props {
  title: string;
  description: string;
  tags: string[];
  image: string;
  link: string;
}

const { title, description, tags, image, link } = Astro.props;
---

<div class="project-card-container">
  <Card href={link} variant="image" class="project-card">
    <div class="card-image-wrapper">
      <img src={image} alt={title} class="card-image" loading="lazy" />
      <div class="card-image-overlay"></div>
      <div class="card-tags-overlay">
        {tags.map((tag) => <span class="card-tag">{tag}</span>)}
      </div>
    </div>
    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      <p class="card-desc">{description}</p>
      <div class="card-action">
        <span>Ver proyecto</span>
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </Card>
</div>

<style>
  .project-card-container {
    grid-column: span 6;
  }

  .project-card {
    height: 100%;
  }

  .card-tags-overlay {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    z-index: 2;
  }

  .card-tags-overlay .card-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-primary);
    background-color: rgba(13, 13, 12, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
  }

  .card-title {
    font-size: 1.8rem;
  }

  .card-desc {
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .card-action {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .card-action svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .project-card:hover .card-action svg {
    transform: translateX(6px);
  }

  /* Asymmetry layout variation */
  @media (min-width: 900px) {
    .project-card-container:nth-child(even) {
      transform: translateY(3rem);
    }
  }

  @media (max-width: 900px) {
    .project-card-container {
      grid-column: span 12;
    }
    .project-card-container:nth-child(even) {
      transform: none;
    }
    .card-image {
      filter: grayscale(0%);
    }
    .card-body {
      padding: 1.75rem;
    }
  }

  @media (max-width: 768px) {
    .card-body {
      padding: 1.5rem;
      gap: 0.6rem;
    }
    .card-title {
      font-size: 1.5rem;
    }
    .card-desc {
      font-size: 0.9rem;
    }
    .card-tags-overlay {
      top: 1rem;
      left: 1rem;
      gap: 0.4rem;
    }
    .card-tags-overlay .card-tag {
      font-size: 0.7rem;
      padding: 0.2rem 0.6rem;
    }
    .card-action {
      margin-top: 0.75rem;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .card-body {
      padding: 1.25rem;
      gap: 0.5rem;
    }
    .card-title {
      font-size: 1.3rem;
    }
    .card-desc {
      font-size: 0.85rem;
      line-height: 1.4;
    }
    .card-tags-overlay {
      top: 0.75rem;
      left: 0.75rem;
      gap: 0.35rem;
    }
    .card-tags-overlay .card-tag {
      font-size: 0.65rem;
      padding: 0.15rem 0.5rem;
    }
    .card-action {
      margin-top: 0.5rem;
      font-size: 0.8rem;
    }
    .card-action svg {
      width: 16px;
      height: 16px;
    }
  }
</style>
