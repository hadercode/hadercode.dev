---
interface Props {
  title: string;
  description: string;
  tags: string[];
  image: string;
  link: string;
}

const { title, description, tags, image, link } = Astro.props;
---

<div class="project-card-container">
  <a href={link} class="project-card hover-link" data-cursor-expand>
    <div class="card-image-wrapper">
      <img src={image} alt={title} class="card-image" loading="lazy" />
      <div class="card-overlay"></div>
      <div class="tags-container">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
    
    <div class="card-content">
      <h3 class="card-title">{title}</h3>
      <p class="card-desc">{description}</p>
      <div class="card-action">
        <span class="action-text">Ver proyecto</span>
        <svg class="action-arrow" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </a>
</div>

<style>
  .project-card-container {
    perspective: 1000px;
    grid-column: span 6; /* Ocupa la mitad en pantallas de 12 col */
  }

  /* El truco del 3D es el transform-style y perspective */
  .project-card {
    display: block;
    background-color: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    overflow: hidden;
    height: 100%;
    transform-style: preserve-3d;
    transform: perspective(1000px) rotateX(var(--rotate-x, 0deg)) rotateY(var(--rotate-y, 0deg)) scale3d(1, 1, 1);
    transition: transform 0.5s var(--ease-out-expo), border-color 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 10px 30px -15px rgba(0, 0, 0, 0.3);
  }

  .project-card:hover {
    border-color: rgba(212, 255, 63, 0.2);
    box-shadow: 0 20px 40px -20px rgba(212, 255, 63, 0.08);
  }

  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    transform: translateZ(20px); /* Eleva la imagen en el espacio 3D */
    transition: transform 0.5s var(--ease-out-expo);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(80%) contrast(1.1);
    transition: transform 0.8s var(--ease-out-expo), filter 0.8s var(--ease-out-expo);
  }

  .project-card:hover .card-image {
    transform: scale(1.08);
    filter: grayscale(0%) contrast(1);
  }

  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 60%, rgba(13, 13, 12, 0.85));
    opacity: 0.8;
    transition: opacity 0.5s ease;
  }

  .project-card:hover .card-overlay {
    opacity: 0.6;
  }

  .tags-container {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    z-index: 2;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-primary);
    background-color: rgba(13, 13, 12, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }

  .card-content {
    padding: 2rem;
    transform: translateZ(40px); /* Eleva el contenido del texto aún más en el espacio 3D */
    transition: transform 0.5s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text-primary);
    transition: color 0.3s ease;
  }

  .project-card:hover .card-title {
    color: var(--accent-primary);
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .card-action {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .action-arrow {
    width: 18px;
    height: 18px;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .project-card:hover .action-arrow {
    transform: translateX(6px);
  }

  /* Asymmetry layout variation */
  @media (min-width: 900px) {
    .project-card-container:nth-child(even) {
      transform: translateY(3rem);
    }
  }

  @media (max-width: 900px) {
    .project-card-container {
      grid-column: span 12;
    }
    .project-card-container:nth-child(even) {
      transform: none;
    }
    .card-image {
      filter: grayscale(0%);
    }
  }

  @media (max-width: 480px) {
    .project-card {
      border-radius: 12px;
    }
    .card-content {
      padding: 1.25rem;
      gap: 0.5rem;
    }
    .card-title {
      font-size: 1.35rem;
    }
    .card-desc {
      font-size: 0.85rem;
    }
    .tags-container {
      top: 0.75rem;
      left: 0.75rem;
      gap: 0.35rem;
    }
    .tag {
      font-size: 0.65rem;
      padding: 0.15rem 0.5rem;
    }
    .card-action {
      margin-top: 0.5rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  function initTiltEffect() {
    const cards = document.querySelectorAll('.project-card') as NodeListOf<HTMLElement>;
    
    // Solo aplicar tilt en computadoras con puntero fino (mouse)
    if (window.matchMedia('(pointer: coarse)').matches) return;

    cards.forEach((card) => {
      const maxRotation = 10; // grados máximos de inclinación

      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        
        // Coordenadas locales dentro de la tarjeta
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        // Coordenadas normalizadas (-1 a 1) desde el centro
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((centerY - y) / centerY) * maxRotation;
        const rotateY = ((x - centerX) / centerX) * maxRotation;

        card.style.setProperty('--rotate-x', `${rotateX}deg`);
        card.style.setProperty('--rotate-y', `${rotateY}deg`);
      });

      card.addEventListener('mouseleave', () => {
        // Resetear inclinación suavemente
        card.style.transition = 'transform 0.8s var(--ease-out-expo), border-color 0.3s ease, box-shadow 0.3s ease';
        card.style.setProperty('--rotate-x', '0deg');
        card.style.setProperty('--rotate-y', '0deg');
        
        // Quitar la transición extra después de que termine para no entorpecer el movimiento del mouse
        setTimeout(() => {
          card.style.transition = '';
        }, 800);
      });
      
      card.addEventListener('mouseenter', () => {
        card.style.transition = ''; // Eliminar transición durante el mousemove
      });
    });
  }

  document.addEventListener('astro:page-load', initTiltEffect);
</script>
