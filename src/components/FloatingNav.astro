---

---

<header class="main-header">
  <div class="header-container">
    <div class="logo">
      <a href="/" class="hover-link" data-cursor-expand>
        <span class="mono">&lt;</span>hadercode<span class="mono">&gt;</span>
      </a>
    </div>

    <nav class="nav-menu" id="nav-menu">
      <ul class="nav-list mono">
        <li class="nav-item">
          <a href="/" class="nav-link hover-link" data-cursor-expand>
            <span class="nav-dot">•</span> inicio
          </a>
        </li>
        <li class="nav-item">
          <a href="/blog" class="nav-link hover-link" data-cursor-expand>
            <span class="nav-dot">•</span> bitácora
          </a>
        </li>
        <li class="nav-item has-megamenu">
          <a
            href="/projects"
            class="nav-link hover-link megamenu-trigger"
            data-cursor-expand
          >
            <span class="nav-dot">•</span> proyectos <span class="arrow"
              >&darr;</span
            >
          </a>

          <!-- MEGAMENU PANEL -->
          <div class="megamenu-panel">
            <div class="megamenu-content">
              <div class="megamenu-left">
                <span class="megamenu-label">// PROJECTS_DATABASE</span>
                <h3 class="megamenu-title">Explora mis desarrollos</h3>
                <p class="megamenu-desc">
                  Una colección de experimentos, herramientas y productos
                  desarrollados con foco en rendimiento extremo y UI refinada.
                </p>
                <a
                  href="/projects"
                  class="megamenu-btn hover-link"
                  data-cursor-expand
                >
                  inspect_all_projects() &rarr;
                </a>
              </div>
              <div class="megamenu-right">
                <div class="megamenu-grid">
                  <!-- Project Mini-Card 1 -->
                  <a
                    href="/projects"
                    class="megamenu-project-card hover-link"
                    data-cursor-expand
                  >
                    <span class="project-num">(01)</span>
                    <div class="project-info">
                      <h4 class="project-name">Docker + Nginx</h4>
                      <p class="project-summary">
                        Despliegue rápido en AWS EC2 con SSL automatizado.
                      </p>
                      <span class="project-tech">DevOps / Nginx</span>
                    </div>
                  </a>

                  <!-- Project Mini-Card 2 -->
                  <a
                    href="/projects"
                    class="megamenu-project-card hover-link"
                    data-cursor-expand
                  >
                    <span class="project-num">(02)</span>
                    <div class="project-info">
                      <h4 class="project-name">Astro Framework</h4>
                      <p class="project-summary">
                        Arquitectura de islas y rendimiento estático impecable.
                      </p>
                      <span class="project-tech">Frontend / Astro</span>
                    </div>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </li>
        <li class="nav-item">
          <a href="/tools" class="nav-link hover-link" data-cursor-expand>
            <span class="nav-dot">•</span> herramientas
          </a>
        </li>
        <li class="nav-item">
          <a href="/contact" class="nav-link hover-link" data-cursor-expand>
            <span class="nav-dot">•</span> contacto
          </a>
        </li>
      </ul>
    </nav>

    <button
      id="menu-toggle"
      class="menu-btn"
      aria-label="Abrir Menú"
      data-cursor-expand
    >
      <div class="btn-line line-top"></div>
      <div class="btn-line line-bottom"></div>
    </button>
  </div>
</header>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4.5rem;
    z-index: 100;
    background-color: rgba(13, 13, 12, 0.7);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    padding: 0 2rem;
    transition: background-color 0.3s ease;
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
  }

  .logo a {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }

  .logo .mono {
    font-family: var(--font-mono);
    color: var(--accent-primary);
    font-size: 1.1rem;
    font-weight: 400;
  }

  /* Nav menu list */
  .nav-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-item {
    /* position: relative removed on base items */
  }

  .has-megamenu {
    position: relative;
  }

  /* Hover bridge to bridge the vertical gap between link and panel without covering other links */
  .has-megamenu::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: 140%; /* slightly wider than the proyectos link only */
    height: 2.5rem; /* extends to meet the megamenu panel top */
    background: transparent;
    z-index: 10;
    pointer-events: none;
  }

  .has-megamenu:hover::after {
    pointer-events: auto;
  }

  .nav-link {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
    transition: color 0.2s var(--ease-out-expo);
  }

  .nav-dot {
    color: var(--accent-primary);
    opacity: 0;
    transform: scale(0);
    transition:
      opacity 0.2s var(--ease-out-expo),
      transform 0.2s var(--ease-out-expo);
  }

  /* Hover & Active Link */
  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link:hover .nav-dot {
    opacity: 1;
    transform: scale(1);
  }

  /* Arrow animation for megamenu trigger */
  .arrow {
    font-size: 0.8rem;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .has-megamenu:hover .arrow {
    transform: translateY(2px);
  }

  /* Megamenu Panel */
  .megamenu-panel {
    position: fixed;
    top: 4.5rem; /* Aligns exactly below the main-header */
    left: 0;
    width: 100%;
    background-color: var(--bg-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    z-index: 99;
    padding: 4rem 2rem;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-10px);
    transition:
      opacity 0.3s var(--ease-out-expo),
      transform 0.3s var(--ease-out-expo);
    box-shadow: 0 40px 80px -30px rgba(0, 0, 0, 0.7);
  }

  /* Hover to trigger megamenu */
  .has-megamenu:hover .megamenu-panel,
  .megamenu-panel:hover {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .megamenu-content {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 6rem;
  }

  .megamenu-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .megamenu-label {
    font-family: var(--font-mono);
    color: var(--accent-primary);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  .megamenu-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
    color: var(--text-primary);
  }

  .megamenu-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .megamenu-btn {
    font-family: var(--font-mono);
    color: var(--accent-secondary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .megamenu-btn:hover {
    color: var(--accent-primary);
  }

  .megamenu-right {
    display: flex;
    align-items: center;
  }

  .megamenu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    width: 100%;
  }

  .megamenu-project-card {
    background-color: var(--bg-primary);
    border: 1px solid rgba(255, 255, 255, 0.03);
    padding: 2rem;
    border-radius: 6px;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .megamenu-project-card:hover {
    border-color: rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.01);
  }

  .project-num {
    font-family: var(--font-mono);
    color: var(--accent-primary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .project-summary {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .project-tech {
    font-family: var(--font-mono);
    color: var(--accent-secondary);
    font-size: 0.75rem;
    margin-top: 0.5rem;
  }

  /* Hamburger Menu Button (for Mobile) */
  .menu-btn {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    width: 32px;
    height: 32px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 6px;
    z-index: 102;
  }

  .btn-line {
    height: 2px;
    background-color: var(--text-primary);
    transition:
      transform 0.3s var(--ease-out-expo),
      width 0.3s var(--ease-out-expo);
  }

  .line-top {
    width: 24px;
  }
  .line-bottom {
    width: 14px;
  }

  /* Mobile Responsive styling */
  @media (max-width: 768px) {
    .menu-btn {
      display: flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: rgba(23, 23, 21, 0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding: 2rem;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition:
        opacity 0.3s var(--ease-out-expo),
        transform 0.3s var(--ease-out-expo),
        visibility 0.3s;
    }

    .nav-menu.active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .megamenu-panel {
      display: none; /* Ocultar megamenu complejo en móvil */
    }

    /* Active Hamburger */
    .menu-btn.active .line-top {
      transform: translateY(4px) rotate(45deg);
      width: 24px;
    }

    .menu-btn.active .line-bottom {
      transform: translateY(-4px) rotate(-45deg);
      width: 24px;
    }
  }
</style>

<script>
  function setupNavigation() {
    const menuToggle = document.getElementById("menu-toggle");
    const navMenu = document.getElementById("nav-menu");
    const navLinks = document.querySelectorAll(
      ".nav-link, .logo a, .megamenu-project-card, .megamenu-btn",
    );

    if (!menuToggle || !navMenu) return;

    function toggleMenu() {
      const isOpen = menuToggle!!.classList.contains("active");
      if (isOpen) {
        menuToggle!!.classList.remove("active");
        navMenu!!.classList.remove("active");
        document.body.style.overflow = "";
      } else {
        menuToggle!!.classList.add("active");
        navMenu!!.classList.add("active");
        document.body.style.overflow = "hidden";
      }
    }

    menuToggle.addEventListener("click", toggleMenu);

    // Cerrar al hacer click en cualquier link
    navLinks.forEach((link) => {
      link.addEventListener("click", () => {
        menuToggle.classList.remove("active");
        navMenu.classList.remove("active");
        document.body.style.overflow = "";
      });
    });
  }

  // Ejecutar tanto en la carga inicial como en cada transición de ViewTransitions
  document.addEventListener("astro:page-load", setupNavigation);
</script>
