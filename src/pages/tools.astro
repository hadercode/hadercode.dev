---
import Layout from "../layouts/Layout.astro";
import type { Tool, Roadmap } from "../types/tools";
import { tools } from "../data/tools";
import { roadmaps } from "../data/roadmaps";
import "../styles/tools.css";

// Contar herramientas por categoría
const categoriesCount = tools.reduce(
  (acc, tool) => {
    acc[tool.category] = (acc[tool.category] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>,
);

const totalToolsCount = tools.length;
---

<Layout
  title="Herramientas & Hojas de Ruta"
  description="Colección seleccionada de utilidades técnicas, extensiones de desarrollo y rutas de aprendizaje paso a paso para ingeniería de software."
>
  <!-- Botón Flotante de Filtrado (Móvil) -->
  <button
    id="mobile-filter-btn"
    class="mobile-filter-btn mono"
    aria-label="Filtrar categorías"
    data-cursor-expand
  >
    <svg
      viewBox="0 0 24 24"
      width="18"
      height="18"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
    </svg>
    <span>filtrar_cat()</span>
  </button>

  <!-- Modal de Filtros (Móvil) -->
  <div id="filter-modal" class="filter-modal">
    <div class="filter-modal-backdrop" id="filter-modal-backdrop"></div>
    <div class="filter-modal-content">
      <div class="filter-modal-header">
        <span class="modal-title mono">// SELECT_FILTER_CATEGORY</span>
        <button
          id="close-filter-modal"
          class="close-modal-btn mono"
          aria-label="Cerrar modal">[x]</button
        >
      </div>
      <div class="filter-modal-body">
        <ul class="modal-category-list mono">
          <li>
            <button
              class="modal-category-btn active hover-link"
              data-category="all"
            >
              <span class="btn-indicator">[*]</span> todos/ ({totalToolsCount})
            </button>
          </li>
          <li>
            <button
              class="modal-category-btn hover-link"
              data-category="plugins"
            >
              <span class="btn-indicator">[ ]</span> plugins/ ({
                categoriesCount.plugins || 0
              })
            </button>
          </li>
          <li>
            <button
              class="modal-category-btn hover-link"
              data-category="extensiones"
            >
              <span class="btn-indicator">[ ]</span> extensiones/ ({
                categoriesCount.extensiones || 0
              })
            </button>
          </li>
          <li>
            <button
              class="modal-category-btn hover-link"
              data-category="componentes"
            >
              <span class="btn-indicator">[ ]</span> componentes/ ({
                categoriesCount.componentes || 0
              })
            </button>
          </li>
          <li>
            <button
              class="modal-category-btn hover-link"
              data-category="frameworks"
            >
              <span class="btn-indicator">[ ]</span> frameworks/ ({
                categoriesCount.frameworks || 0
              })
            </button>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <section class="tools-header">
    <div class="section-header-code">
      <span class="syntax-keyword">import</span> &#123; <span class="syntax-fn"
        >developerToolkit</span
      > &#125; <span class="syntax-keyword">from</span>
      <span class="syntax-string">'hadercode/tools'</span>;
    </div>
    <h1 class="header-title">Tools & <br /> Roadmap</h1>
    <p class="header-desc">
      Un compendio interactivo de recursos técnicos, utilidades de desarrollo y
      guías de aprendizaje estructuradas para potenciar tu crecimiento como
      ingeniero de software.
    </p>
  </section>

  <!-- Pestañas Principales (Tabs) -->
  <div class="tabs-header mono">
    <button
      class="tab-trigger active hover-link"
      data-target="toolkit"
      data-cursor-expand
    >
      <span class="num">[01]</span> toolkit.env
    </button>
    <button
      class="tab-trigger hover-link"
      data-target="roadmaps"
      data-cursor-expand
    >
      <span class="num">[02]</span> roadmaps.sh
    </button>
  </div>

  <!-- PANELES DE CONTENIDO -->
  <div class="tab-panels-wrapper">
    <!-- PANEL 1: CAJA DE HERRAMIENTAS -->
    <div id="toolkit-tab-content" class="tab-panel active">
      <div class="tools-page-grid">
        <!-- Sidebar de Categorías -->
        <aside class="tools-sidebar">
          <div class="sidebar-sticky">
            <div class="category-box">
              <div class="terminal-cmd mono">$ ls -F content/tools/</div>
              <ul class="category-list mono">
                <li>
                  <button
                    class="category-btn active hover-link"
                    data-category="all"
                    data-cursor-expand
                  >
                    <span class="tree-line">├──</span>
                    <span class="btn-indicator">[*]</span>
                    <span class="btn-name">todos/</span>
                    <span class="btn-count">({totalToolsCount})</span>
                  </button>
                </li>
                <li>
                  <button
                    class="category-btn hover-link"
                    data-category="plugins"
                    data-cursor-expand
                  >
                    <span class="tree-line">├──</span>
                    <span class="btn-indicator">[ ]</span>
                    <span class="btn-name">plugins/</span>
                    <span class="btn-count"
                      >({categoriesCount.plugins || 0})</span
                    >
                  </button>
                </li>
                <li>
                  <button
                    class="category-btn hover-link"
                    data-category="extensiones"
                    data-cursor-expand
                  >
                    <span class="tree-line">├──</span>
                    <span class="btn-indicator">[ ]</span>
                    <span class="btn-name">extensiones/</span>
                    <span class="btn-count"
                      >({categoriesCount.extensiones || 0})</span
                    >
                  </button>
                </li>
                <li>
                  <button
                    class="category-btn hover-link"
                    data-category="componentes"
                    data-cursor-expand
                  >
                    <span class="tree-line">├──</span>
                    <span class="btn-indicator">[ ]</span>
                    <span class="btn-name">componentes/</span>
                    <span class="btn-count"
                      >({categoriesCount.componentes || 0})</span
                    >
                  </button>
                </li>
                <li>
                  <button
                    class="category-btn hover-link"
                    data-category="frameworks"
                    data-cursor-expand
                  >
                    <span class="tree-line">└──</span>
                    <span class="btn-indicator">[ ]</span>
                    <span class="btn-name">frameworks/</span>
                    <span class="btn-count"
                      >({categoriesCount.frameworks || 0})</span
                    >
                  </button>
                </li>
              </ul>
            </div>
          </div>
        </aside>

        <!-- Grid de Herramientas -->
        <div class="tools-list-container">
          <div class="tools-grid" id="tools-grid">
            {
              tools.map((tool, index) => (
                <div
                  class={`tool-card ${tool.highlight ? "featured" : ""} animate-fade-in`}
                  data-category={tool.category}
                >
                  <div class="card-header">
                    <span class="card-num mono">
                      ({String(index + 1).padStart(2, "0")})
                    </span>
                    <span class="card-category mono">
                      //{tool.category.toUpperCase()}
                    </span>
                  </div>
                  <div class="card-body">
                    <h3 class="card-name">{tool.name}</h3>
                    <p class="card-desc">{tool.description}</p>
                    <div class="card-tags">
                      {tool.tags.map((tag) => (
                        <span class="card-tag mono">
                          tech::{tag.toLowerCase()}
                        </span>
                      ))}
                    </div>
                  </div>
                  <div class="card-action">
                    <a
                      href={tool.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="action-btn hover-link mono"
                      data-cursor-expand
                    >
                      open_resource() &rarr;
                    </a>
                  </div>
                </div>
              ))
            }
          </div>

          <div
            class="no-results-message"
            id="no-results"
            style="display: none; opacity: 0; transition: opacity 0.3s ease;"
          >
            <p class="mono">
              // NO_TOOLS_FOUND: no se encontraron herramientas en esta
              categoría.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- PANEL 2: RUTAS DE APRENDIZAJE -->
    <div id="roadmaps-tab-content" class="tab-panel">
      <div class="roadmaps-layout">
        <!-- Selector de Hojas de Ruta -->
        <div class="roadmap-selector mono">
          {
            roadmaps.map((rm, idx) => (
              <button
                class={`roadmap-selector-btn ${idx === 0 ? "active" : ""} hover-link`}
                data-roadmap={rm.id}
                data-cursor-expand
              >
                {rm.name}
              </button>
            ))
          }
        </div>

        <!-- Timelines de cada Roadmap -->
        <div class="roadmaps-timeline-container">
          {
            roadmaps.map((rm, idx) => (
              <div
                class={`roadmap-timeline-wrapper ${idx === 0 ? "active" : ""}`}
                id={`roadmap-wrapper-${rm.id}`}
              >
                <div class="roadmap-info-header">
                  <h2 class="roadmap-title mono">
                    // {rm.id.toUpperCase()}_PATH
                  </h2>
                  <p class="roadmap-description">{rm.description}</p>
                </div>

                <div class="timeline">
                  {rm.steps.map((st) => (
                    <div class="timeline-node">
                      <div class="timeline-dot" />
                      <div class="timeline-step mono">{st.step}</div>
                      <h3 class="timeline-node-title">{st.title}</h3>
                      <p class="timeline-desc">{st.desc}</p>

                      <div class="timeline-meta">
                        <div class="meta-list">
                          <span class="meta-label mono">concepts:</span>
                          {st.concepts.map((concept) => (
                            <span class="meta-badge mono">{concept}</span>
                          ))}
                        </div>
                        <div class="meta-list">
                          <span class="meta-label mono">resources:</span>
                          {st.resources.map((resource) => (
                            <span class="meta-badge highlight-badge mono">
                              {resource}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>



<script>
  function setupToolsAndRoadmaps() {
    // 1. Control de Pestañas Principales (Tab Switching)
    const tabTriggers = document.querySelectorAll(".tab-trigger");
    const tabPanels = document.querySelectorAll(".tab-panel");

    tabTriggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const target = trigger.getAttribute("data-target");

        // Toggle active triggers
        tabTriggers.forEach((t) => t.classList.remove("active"));
        trigger.classList.add("active");

        // Toggle active panels
        tabPanels.forEach((panel) => {
          panel.classList.remove("active");
          if (panel.id === `${target}-tab-content`) {
            panel.classList.add("active");
          }
        });
      });
    });

    // 2. Control de Filtrado de la Caja de Herramientas
    const categoryButtons = document.querySelectorAll(".category-btn");
    const modalCategoryButtons = document.querySelectorAll(
      ".modal-category-btn",
    );
    const toolCards = document.querySelectorAll(".tool-card");
    const noResultsMsg = document.getElementById("no-results");

    // Modal elements
    const mobileFilterBtn = document.getElementById("mobile-filter-btn");
    const filterModal = document.getElementById("filter-modal");
    const closeFilterModalBtn = document.getElementById("close-filter-modal");
    const filterModalBackdrop = document.getElementById(
      "filter-modal-backdrop",
    );

    // Modal open/close handlers
    if (mobileFilterBtn && filterModal) {
      mobileFilterBtn.addEventListener("click", () => {
        filterModal.classList.add("active");
        document.body.style.overflow = "hidden"; // block background scroll
      });

      const closeModal = () => {
        filterModal.classList.remove("active");
        document.body.style.overflow = "";
      };

      if (closeFilterModalBtn)
        closeFilterModalBtn.addEventListener("click", closeModal);
      if (filterModalBackdrop)
        filterModalBackdrop.addEventListener("click", closeModal);

      // Close modal on escape key
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && filterModal.classList.contains("active")) {
          closeModal();
        }
      });
    }

    function applyCategoryFilter(category: any) {
      // Sync active state for BOTH sidebar buttons and modal buttons
      const allFilterBtns = [
        ...Array.from(categoryButtons),
        ...Array.from(modalCategoryButtons),
      ];

      allFilterBtns.forEach((btn) => {
        const btnCategory = btn.getAttribute("data-category");
        const indicator = btn.querySelector(".btn-indicator");

        if (btnCategory === category) {
          btn.classList.add("active");
          if (indicator) indicator.textContent = "[*]";
        } else {
          btn.classList.remove("active");
          if (indicator) indicator.textContent = "[ ]";
        }
      });

      // Filter tools grid
      let visibleCount = 0;
      toolCards.forEach((card) => {
        const cardCategory = card.getAttribute("data-category");
        const matches = category === "all" || cardCategory === category;
        const htmlCard = card as HTMLElement;

        if (matches) {
          htmlCard.style.display = "flex";
          htmlCard.offsetHeight; // force reflow
          htmlCard.style.opacity = "1";
          htmlCard.style.transform = "translateY(0)";
          visibleCount++;
        } else {
          htmlCard.style.opacity = "0";
          htmlCard.style.transform = "translateY(10px)";
          setTimeout(() => {
            if (htmlCard.style.opacity === "0") {
              htmlCard.style.display = "none";
            }
          }, 300);
        }
      });

      // Show/hide no results message
      if (noResultsMsg) {
        if (visibleCount === 0) {
          setTimeout(() => {
            if (visibleCount === 0) {
              noResultsMsg.style.display = "block";
              noResultsMsg.offsetHeight;
              noResultsMsg.style.opacity = "1";
            }
          }, 300);
        } else {
          noResultsMsg.style.opacity = "0";
          noResultsMsg.style.display = "none";
        }
      }
    }

    if (categoryButtons.length && toolCards.length) {
      categoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const category = button.getAttribute("data-category");
          if (category) applyCategoryFilter(category);
        });
      });
    }

    if (modalCategoryButtons.length && toolCards.length) {
      modalCategoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const category = button.getAttribute("data-category");
          if (category) {
            applyCategoryFilter(category);
            // Close modal after selection
            if (filterModal) {
              filterModal.classList.remove("active");
              document.body.style.overflow = "";
            }
          }
        });
      });
    }

    // 3. Control de Selector de Hojas de Ruta (Roadmaps Switching)
    const roadmapSelectorButtons = document.querySelectorAll(
      ".roadmap-selector-btn",
    );
    const roadmapWrappers = document.querySelectorAll(
      ".roadmap-timeline-wrapper",
    );

    if (roadmapSelectorButtons.length && roadmapWrappers.length) {
      roadmapSelectorButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const targetRoadmap = btn.getAttribute("data-roadmap");

          // Toggle selector active states
          roadmapSelectorButtons.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");

          // Toggle roadmap wrapper active states
          roadmapWrappers.forEach((wrapper) => {
            wrapper.classList.remove("active");
            if (wrapper.id === `roadmap-wrapper-${targetRoadmap}`) {
              wrapper.classList.add("active");
            }
          });
        });
      });
    }

    // 4. Leer parámetros de URL para auto-inicializar filtros o pestañas
    const params = new URLSearchParams(window.location.search);

    // Auto-activar la pestaña de roadmaps si viene en la query '?tab=roadmaps' o '?roadmap=...'
    const tabParam = params.get("tab");
    const roadmapParam = params.get("roadmap");

    if (tabParam === "roadmaps" || roadmapParam) {
      const roadmapsTabTrigger = Array.from(tabTriggers).find(
        (t) => t.getAttribute("data-target") === "roadmaps",
      );
      if (roadmapsTabTrigger) {
        (roadmapsTabTrigger as HTMLButtonElement).click();
      }

      if (roadmapParam) {
        const activeRoadmapBtn = Array.from(roadmapSelectorButtons).find(
          (btn) =>
            btn.getAttribute("data-roadmap")?.toLowerCase() ===
            roadmapParam.toLowerCase(),
        );
        if (activeRoadmapBtn) {
          (activeRoadmapBtn as HTMLButtonElement).click();
        }
      }
    } else {
      // Auto-inicializar filtro de herramientas si viene en la query '?category=...'
      const categoryParam = params.get("category");
      if (categoryParam) {
        const activeCategoryBtn = Array.from(categoryButtons).find(
          (btn) =>
            btn.getAttribute("data-category")?.toLowerCase() ===
            categoryParam.toLowerCase(),
        );
        if (activeCategoryBtn) {
          (activeCategoryBtn as HTMLButtonElement).click();
        }
      }
    }
  }

  // Ejecutar tanto en la carga inicial como en cada transición de ViewTransitions
  document.addEventListener("astro:page-load", setupToolsAndRoadmaps);
</script>
