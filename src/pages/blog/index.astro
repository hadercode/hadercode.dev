---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import "../../styles/blog-list.css";

const posts = await getCollection("blog", ({ data }) => {
  return !data.draft;
});

// Ordenar por fecha descendente
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Extraer categorías únicas y contar posts
const categoriesCount = sortedPosts.reduce(
  (acc, post) => {
    const cat = post.data.category || "General";
    acc[cat] = (acc[cat] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>,
);

const categoriesList = Object.entries(categoriesCount)
  .map(([name, count]) => ({
    name,
    count,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

const totalPostsCount = sortedPosts.length;
---

<Layout
  title="Bitácora Técnica"
  description="Artículos de desarrollo de software, arquitectura frontend moderna, optimización de rendimiento y el ecosistema web."
>
  <!-- Botón Flotante de Filtrado (Móvil) -->
  <button
    id="mobile-filter-btn"
    class="mobile-filter-btn mono"
    aria-label="Filtrar categorías"
    data-cursor-expand
  >
    <svg
      viewBox="0 0 24 24"
      width="18"
      height="18"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
    </svg>
    <span>filtrar_cat()</span>
  </button>

  <!-- Modal de Filtros (Móvil) -->
  <div id="filter-modal" class="filter-modal">
    <div class="filter-modal-backdrop" id="filter-modal-backdrop"></div>
    <div class="filter-modal-content">
      <div class="filter-modal-header">
        <span class="modal-title mono">// SELECT_FILTER_CATEGORY</span>
        <button
          id="close-filter-modal"
          class="close-modal-btn mono"
          aria-label="Cerrar modal">[x]</button
        >
      </div>
      <div class="filter-modal-body">
        <ul class="modal-category-list mono">
          <li>
            <button
              class="modal-category-btn active hover-link"
              data-category="all"
            >
              <span class="btn-indicator">[*]</span> todos/ ({totalPostsCount})
            </button>
          </li>
          {
            categoriesList.map((cat) => (
              <li>
                <button
                  class="modal-category-btn hover-link"
                  data-category={cat.name}
                >
                  <span class="btn-indicator">[ ]</span>{" "}
                  {cat.name.toLowerCase()}/ ({cat.count})
                </button>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <section class="blog-header">
    <div class="section-header-code">
      <span class="syntax-keyword">import</span> &#123; <span class="syntax-fn"
        >technicalJournal</span
      > &#125; <span class="syntax-keyword">from</span>
      <span class="syntax-string">'had.code/blog'</span>;
    </div>
    <h1 class="header-title">Bitácora</h1>
    <p class="header-desc">
      Un espacio donde compilo mis notas, investigaciones técnicas sobre
      arquitectura de código, análisis de rendimiento y desarrollo web modular.
    </p>
  </section>

  <section class="blog-list-section">
    <div class="blog-content-layout">
      <!-- Sidebar de Categorías -->
      <aside class="blog-sidebar">
        <div class="sidebar-block">
          <div class="sidebar-header mono">
            <span>// FILTER_BY_CATEGORY</span>
          </div>
          <div class="terminal-tree">
            <div class="terminal-cmd mono">$ ls -F content/blog/</div>
            <ul class="category-list mono">
              <li>
                <button
                  class="category-btn active hover-link"
                  data-category="all"
                  data-cursor-expand
                >
                  <span class="tree-line">├──</span>
                  <span class="btn-indicator">[*]</span>
                  <span class="btn-name">todos/</span>
                  <span class="btn-count">({totalPostsCount})</span>
                </button>
              </li>
              {
                categoriesList.map((cat, idx) => {
                  const isLast = idx === categoriesList.length - 1;
                  const treeConnector = isLast ? "└──" : "├──";
                  return (
                    <li>
                      <button
                        class="category-btn hover-link"
                        data-category={cat.name}
                        data-cursor-expand
                      >
                        <span class="tree-line">{treeConnector}</span>
                        <span class="btn-indicator">[ ]</span>
                        <span class="btn-name">{cat.name.toLowerCase()}/</span>
                        <span class="btn-count">({cat.count})</span>
                      </button>
                    </li>
                  );
                })
              }
            </ul>
          </div>
        </div>
      </aside>

      <!-- Grid de Publicaciones -->
      <div class="blog-list-container">
        <div class="blog-grid" id="blog-grid">
          {
            sortedPosts.map((post, index) => (
              <article
                class="blog-card animate-fade-in"
                data-category={post.data.category || "General"}
              >
                <a
                  href={`/blog/${post.id}`}
                  class="blog-card-link hover-link"
                  data-cursor-expand
                >
                  <div class="card-num mono">
                    ({String(index + 1).padStart(2, "0")})
                  </div>
                  <div class="card-body">
                    <span class="card-date mono">
                      // PUBLISHED:{" "}
                      {post.data.pubDate
                        .toLocaleDateString("es-ES", {
                          year: "numeric",
                          month: "short",
                          day: "numeric",
                        })
                        .toUpperCase()}{" "}
                      | CATEGORY:{" "}
                      {post.data.category?.toUpperCase() || "GENERAL"}
                    </span>
                    <h2 class="card-title">{post.data.title}</h2>
                    <p class="card-excerpt">{post.data.description}</p>
                    <div class="card-tags">
                      {post.data.tags.map((tag) => (
                        <span class="card-tag mono">tag::{tag}</span>
                      ))}
                    </div>
                  </div>
                  <div class="card-action">
                    <span class="action-btn">
                      cat entry.md
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M5 12H19M19 12L13 6M19 12L13 18"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </span>
                  </div>
                </a>
              </article>
            ))
          }
        </div>

        <div
          class="no-posts-message"
          id="no-posts"
          style="display: none; opacity: 0; transition: opacity 0.3s ease;"
        >
          <p class="mono">
            // NO_ENTRIES_FOUND: no se encontraron artículos en esta categoría.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>



<script>
  function setupFiltering() {
    const categoryButtons = document.querySelectorAll(".category-btn");
    const modalCategoryButtons = document.querySelectorAll(
      ".modal-category-btn",
    );
    const articles = document.querySelectorAll(".blog-card");
    const noPostsMsg = document.getElementById("no-posts");

    // Modal elements
    const mobileFilterBtn = document.getElementById("mobile-filter-btn");
    const filterModal = document.getElementById("filter-modal");
    const closeFilterModalBtn = document.getElementById("close-filter-modal");
    const filterModalBackdrop = document.getElementById(
      "filter-modal-backdrop",
    );

    // Modal open/close handlers
    if (mobileFilterBtn && filterModal) {
      mobileFilterBtn.addEventListener("click", () => {
        filterModal.classList.add("active");
        document.body.style.overflow = "hidden"; // block background scroll
      });

      const closeModal = () => {
        filterModal.classList.remove("active");
        document.body.style.overflow = "";
      };

      if (closeFilterModalBtn)
        closeFilterModalBtn.addEventListener("click", closeModal);
      if (filterModalBackdrop)
        filterModalBackdrop.addEventListener("click", closeModal);

      // Close modal on escape key
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && filterModal.classList.contains("active")) {
          closeModal();
        }
      });
    }

    function applyCategoryFilter(category: string) {
      // Sync active state for BOTH sidebar buttons and modal buttons
      const allFilterBtns = [
        ...Array.from(categoryButtons),
        ...Array.from(modalCategoryButtons),
      ];

      allFilterBtns.forEach((btn) => {
        const btnCategory = btn.getAttribute("data-category");
        const indicator = btn.querySelector(".btn-indicator");

        if (btnCategory === category) {
          btn.classList.add("active");
          if (indicator) indicator.textContent = "[*]";
        } else {
          btn.classList.remove("active");
          if (indicator) indicator.textContent = "[ ]";
        }
      });

      // Filter and transition articles
      let visibleCount = 0;
      articles.forEach((article) => {
        const artCategory = article.getAttribute("data-category");
        const matches = category === "all" || artCategory === category;
        const htmlArticle = article as HTMLElement;

        if (matches) {
          htmlArticle.style.display = "block";
          // Trigger reflow to restart transition
          htmlArticle.offsetHeight;
          htmlArticle.style.opacity = "1";
          htmlArticle.style.transform = "translateY(0)";
          visibleCount++;
        } else {
          htmlArticle.style.opacity = "0";
          htmlArticle.style.transform = "translateY(10px)";
          // Hide element from layout after fade out
          setTimeout(() => {
            if (htmlArticle.style.opacity === "0") {
              htmlArticle.style.display = "none";
            }
          }, 300);
        }
      });

      // Display/hide empty search message
      if (noPostsMsg) {
        if (visibleCount === 0) {
          setTimeout(() => {
            if (visibleCount === 0) {
              noPostsMsg.style.display = "block";
              // Trigger reflow
              noPostsMsg.offsetHeight;
              noPostsMsg.style.opacity = "1";
            }
          }, 300);
        } else {
          noPostsMsg.style.opacity = "0";
          noPostsMsg.style.display = "none";
        }
      }
    }

    if (categoryButtons.length && articles.length) {
      categoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const category = button.getAttribute("data-category");
          if (category) applyCategoryFilter(category);
        });
      });
    }

    if (modalCategoryButtons.length && articles.length) {
      modalCategoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const category = button.getAttribute("data-category");
          if (category) {
            applyCategoryFilter(category);
            // Close modal after selection
            if (filterModal) {
              filterModal.classList.remove("active");
              document.body.style.overflow = "";
            }
          }
        });
      });
    }

    // Check URL parameters and trigger filter on load
    const params = new URLSearchParams(window.location.search);
    const categoryParam = params.get("category");
    if (categoryParam) {
      const activeBtn = Array.from(categoryButtons).find(
        (btn) =>
          btn.getAttribute("data-category")?.toLowerCase() ===
          categoryParam.toLowerCase(),
      );
      if (activeBtn) {
        (activeBtn as HTMLButtonElement).click();
      }
    }
  }

  // Hook into Astro Page Load cycle (works with ClientRouter)
  document.addEventListener("astro:page-load", setupFiltering);
</script>
