---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => {
  return !data.draft;
});

// Ordenar por fecha descendente
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Extraer categorías únicas y contar posts
const categoriesCount = sortedPosts.reduce(
  (acc, post) => {
    const cat = post.data.category || "General";
    acc[cat] = (acc[cat] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>,
);

const categoriesList = Object.entries(categoriesCount)
  .map(([name, count]) => ({
    name,
    count,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

const totalPostsCount = sortedPosts.length;
---

<Layout
  title="Bitácora Técnica"
  description="Artículos de desarrollo de software, arquitectura frontend moderna, optimización de rendimiento y el ecosistema web."
>
  <section class="blog-header">
    <div class="section-header-code">
      <span class="syntax-keyword">import</span> &#123; <span class="syntax-fn"
        >technicalJournal</span
      > &#125; <span class="syntax-keyword">from</span>
      <span class="syntax-string">'had.code/blog'</span>;
    </div>
    <h1 class="header-title">Bitácora de Ingeniería</h1>
    <p class="header-desc">
      Un espacio donde compilo mis notas, investigaciones técnicas sobre
      arquitectura de código, análisis de rendimiento y desarrollo web modular.
    </p>
  </section>

  <section class="blog-list-section">
    <div class="blog-content-layout">
      <!-- Sidebar de Categorías -->
      <aside class="blog-sidebar">
        <div class="sidebar-block">
          <div class="sidebar-header mono">
            <span>// FILTER_BY_CATEGORY</span>
          </div>
          <div class="terminal-tree">
            <div class="terminal-cmd mono">$ ls -F content/blog/</div>
            <ul class="category-list mono">
              <li>
                <button
                  class="category-btn active hover-link"
                  data-category="all"
                  data-cursor-expand
                >
                  <span class="tree-line">├──</span>
                  <span class="btn-indicator">[*]</span>
                  <span class="btn-name">todos/</span>
                  <span class="btn-count">({totalPostsCount})</span>
                </button>
              </li>
              {
                categoriesList.map((cat, idx) => {
                  const isLast = idx === categoriesList.length - 1;
                  const treeConnector = isLast ? "└──" : "├──";
                  return (
                    <li>
                      <button
                        class="category-btn hover-link"
                        data-category={cat.name}
                        data-cursor-expand
                      >
                        <span class="tree-line">{treeConnector}</span>
                        <span class="btn-indicator">[ ]</span>
                        <span class="btn-name">{cat.name.toLowerCase()}/</span>
                        <span class="btn-count">({cat.count})</span>
                      </button>
                    </li>
                  );
                })
              }
            </ul>
          </div>
        </div>
      </aside>

      <!-- Grid de Publicaciones -->
      <div class="blog-list-container">
        <div class="blog-grid" id="blog-grid">
          {
            sortedPosts.map((post, index) => (
              <article
                class="blog-card animate-fade-in"
                data-category={post.data.category || "General"}
              >
                <a
                  href={`/blog/${post.id}`}
                  class="blog-card-link hover-link"
                  data-cursor-expand
                >
                  <div class="card-num mono">
                    ({String(index + 1).padStart(2, "0")})
                  </div>
                  <div class="card-body">
                    <span class="card-date mono">
                      // PUBLISHED:{" "}
                      {post.data.pubDate
                        .toLocaleDateString("es-ES", {
                          year: "numeric",
                          month: "short",
                          day: "numeric",
                        })
                        .toUpperCase()}{" "}
                      | CATEGORY:{" "}
                      {post.data.category?.toUpperCase() || "GENERAL"}
                    </span>
                    <h2 class="card-title">{post.data.title}</h2>
                    <p class="card-excerpt">{post.data.description}</p>
                    <div class="card-tags">
                      {post.data.tags.map((tag) => (
                        <span class="card-tag mono">tag::{tag}</span>
                      ))}
                    </div>
                  </div>
                  <div class="card-action">
                    <span class="action-btn">
                      cat entry.md
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M5 12H19M19 12L13 6M19 12L13 18"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </span>
                  </div>
                </a>
              </article>
            ))
          }
        </div>

        <div
          class="no-posts-message"
          id="no-posts"
          style="display: none; opacity: 0; transition: opacity 0.3s ease;"
        >
          <p class="mono">
            // NO_ENTRIES_FOUND: no se encontraron artículos en esta categoría.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-header {
    padding: 12rem 0 4rem 0;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .header-title {
    font-size: clamp(3rem, 6vw, 5rem);
    text-transform: uppercase;
    line-height: 1;
  }

  .header-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* List Section */
  .blog-list-section {
    padding-bottom: 8rem;
  }

  .blog-content-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Sidebar */
  .blog-sidebar {
    position: sticky;
    top: 120px;
    padding: 2rem 1.5rem;
    background-color: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 6px;
    backdrop-filter: blur(10px);
  }

  .sidebar-header {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .terminal-cmd {
    font-size: 0.8rem;
    color: var(--accent-secondary);
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .category-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .category-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    cursor: pointer;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.35rem 0;
    transition: color 0.2s var(--ease-out-expo);
  }

  .tree-line {
    color: rgba(255, 255, 255, 0.15);
    font-weight: normal;
  }

  .btn-indicator {
    color: var(--text-secondary);
    transition: color 0.2s var(--ease-out-expo);
  }

  .btn-name {
    color: var(--text-secondary);
    transition: color 0.2s var(--ease-out-expo);
  }

  .btn-count {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.75rem;
    transition: color 0.2s var(--ease-out-expo);
  }

  /* Hover & Active States */
  .category-btn:hover {
    color: var(--accent-primary);
  }

  .category-btn:hover .btn-name {
    color: var(--accent-primary);
  }

  .category-btn:hover .btn-indicator {
    color: var(--accent-primary);
  }

  .category-btn.active .btn-indicator {
    color: var(--accent-primary);
  }

  .category-btn.active .btn-name {
    color: var(--text-primary);
    font-weight: 700;
  }

  .category-btn.active .btn-count {
    color: var(--accent-secondary);
  }

  /* No posts message */
  .no-posts-message {
    padding: 5rem 2rem;
    border: 1px dashed rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    text-align: center;
  }

  .no-posts-message p {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .blog-grid {
    display: flex;
    flex-direction: column;
  }

  .blog-card {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    transition:
      background-color 0.3s ease,
      opacity 0.3s ease,
      transform 0.3s var(--ease-out-expo);
    opacity: 1;
    transform: translateY(0);
  }

  .blog-card:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .blog-card-link {
    display: grid;
    grid-template-columns: 0.5fr 3fr 1.2fr;
    padding: 4rem 0;
    gap: 2rem;
    align-items: flex-start;
  }

  .blog-card:hover {
    background-color: rgba(255, 255, 255, 0.01);
  }

  .card-num {
    font-size: 1.1rem;
    color: var(--accent-primary);
    font-weight: 700;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
  }

  .card-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
    transition: color 0.3s ease;
    line-height: 1.1;
  }

  .blog-card-link:hover .card-title {
    color: var(--accent-primary);
  }

  .card-excerpt {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .card-tag {
    font-size: 0.75rem;
    color: var(--accent-secondary);
    background-color: var(--bg-secondary);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .card-action {
    display: flex;
    justify-content: flex-end;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    transition:
      background-color 0.3s,
      color 0.3s,
      border-color 0.3s;
  }

  .blog-card-link:hover .action-btn {
    background-color: var(--accent-primary);
    color: var(--bg-primary);
    border-color: var(--accent-primary);
  }

  .action-btn svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .blog-card-link:hover .action-btn svg {
    transform: translateX(4px);
  }

  /* Responsive Design */
  @media (max-width: 1000px) {
    .blog-content-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .blog-sidebar {
      position: relative;
      top: 0;
      width: 100%;
      padding: 1.5rem;
    }
  }

  @media (max-width: 900px) {
    .blog-card-link {
      grid-template-columns: 1fr;
      padding: 3rem 0;
      gap: 1.5rem;
    }

    .card-action {
      justify-content: flex-start;
    }
  }
</style>

<script>
  function setupFiltering() {
    const buttons = document.querySelectorAll(".category-btn");
    const articles = document.querySelectorAll(".blog-card");
    const noPostsMsg = document.getElementById("no-posts");

    if (!buttons.length || !articles.length) return;

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const category = button.getAttribute("data-category");

        // Reset all buttons to inactive state
        buttons.forEach((btn) => {
          btn.classList.remove("active");
          const indicator = btn.querySelector(".btn-indicator");
          if (indicator) {
            indicator.textContent = "[ ]";
          }
        });

        // Set clicked button to active state
        button.classList.add("active");
        const activeIndicator = button.querySelector(".btn-indicator");
        if (activeIndicator) {
          activeIndicator.textContent = "[*]";
        }

        // Filter and transition articles
        let visibleCount = 0;
        articles.forEach((article) => {
          const artCategory = article.getAttribute("data-category");
          const matches = category === "all" || artCategory === category;
          const htmlArticle = article as HTMLElement;

          if (matches) {
            htmlArticle.style.display = "block";
            // Trigger reflow to restart transition
            htmlArticle.offsetHeight;
            htmlArticle.style.opacity = "1";
            htmlArticle.style.transform = "translateY(0)";
            visibleCount++;
          } else {
            htmlArticle.style.opacity = "0";
            htmlArticle.style.transform = "translateY(10px)";
            // Hide element from layout after fade out
            setTimeout(() => {
              if (htmlArticle.style.opacity === "0") {
                htmlArticle.style.display = "none";
              }
            }, 300);
          }
        });

        // Display/hide empty search message
        if (noPostsMsg) {
          if (visibleCount === 0) {
            setTimeout(() => {
              if (visibleCount === 0) {
                noPostsMsg.style.display = "block";
                // Trigger reflow
                noPostsMsg.offsetHeight;
                noPostsMsg.style.opacity = "1";
              }
            }, 300);
          } else {
            noPostsMsg.style.opacity = "0";
            noPostsMsg.style.display = "none";
          }
        }
      });
    });

    // Check URL parameters and trigger filter on load
    const params = new URLSearchParams(window.location.search);
    const categoryParam = params.get("category");
    if (categoryParam) {
      const activeBtn = Array.from(buttons).find(
        (btn) =>
          btn.getAttribute("data-category")?.toLowerCase() ===
          categoryParam.toLowerCase(),
      );
      if (activeBtn) {
        (activeBtn as HTMLButtonElement).click();
      }
    }
  }

  // Hook into Astro Page Load cycle (works with ClientRouter)
  document.addEventListener("astro:page-load", setupFiltering);
</script>
