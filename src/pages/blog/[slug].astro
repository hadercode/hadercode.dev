---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import "../../styles/blog-post.css";

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

// Obtener todas las publicaciones para las categorías del sidebar
const posts = await getCollection('blog', ({ data }) => !data.draft);
const categoriesCount = posts.reduce((acc, p) => {
  const cat = p.data.category || 'General';
  acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categoriesList = Object.entries(categoriesCount).map(([name, count]) => ({
  name,
  count
})).sort((a, b) => a.name.localeCompare(b.name));

const totalPostsCount = posts.length;
---

<Layout 
  title={`${post.data.title} — HaderCode`}
  description={post.data.description}
  image={post.data.image}
  ogType="article"
  publishedTime={post.data.pubDate}
  tags={post.data.tags}
>
  <!-- Scroll Progress Bar -->
  <div class="scroll-progress" id="scroll-bar"></div>

  <!-- JSON-LD Datos Estructurados -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "image": post.data.image ? new URL(post.data.image, Astro.site || Astro.url.origin).href : undefined,
    "datePublished": post.data.pubDate.toISOString(),
    "author": {
      "@type": "Person",
      "name": "HaderCode",
      "url": new URL('/', Astro.site || Astro.url.origin).href
    }
  })} />

  <div class="post-layout-wrapper">
    <div class="post-content-layout">
      <!-- Sidebar de Navegación y Búsqueda -->
      <aside class="post-sidebar">
        <!-- Bloque de Categorías -->
        <div class="sidebar-block">
          <div class="sidebar-header mono">
            <span>// FILTER_BY_CATEGORY</span>
          </div>
          <div class="terminal-tree">
            <div class="terminal-cmd mono">$ ls -F content/blog/</div>
            <ul class="category-list mono">
              <li>
                <a href="/blog?category=all" class="category-btn hover-link" data-cursor-expand>
                  <span class="tree-line">├──</span>
                  <span class="btn-indicator">[ ]</span> 
                  <span class="btn-name">todos/</span>
                  <span class="btn-count">({totalPostsCount})</span>
                </a>
              </li>
              {categoriesList.map((cat, idx) => {
                const isLast = idx === categoriesList.length - 1;
                const treeConnector = isLast ? '└──' : '├──';
                const isActive = post.data.category === cat.name;
                return (
                  <li>
                    <a href={`/blog?category=${cat.name}`} class={`category-btn hover-link ${isActive ? 'active' : ''}`} data-cursor-expand>
                      <span class="tree-line">{treeConnector}</span>
                      <span class="btn-indicator">{isActive ? '[*]' : '[ ]'}</span> 
                      <span class="btn-name">{cat.name.toLowerCase()}/</span>
                      <span class="btn-count">({cat.count})</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>

        <!-- Bloque del Buscador grep -->
        <div class="sidebar-block search-block">
          <div class="sidebar-header mono">
            <span>// SEARCH_IN_PAGE</span>
          </div>
          <div class="terminal-search mono">
            <div class="terminal-cmd">$ grep -in <span class="syntax-keyword">"term"</span> post.md</div>
            <div class="search-input-wrapper">
              <span class="prompt">$</span>
              <input type="text" id="grep-input" class="grep-input" placeholder="buscar texto..." autocomplete="off" data-cursor-expand />
            </div>
            <div id="search-stats" class="search-stats" style="display: none; opacity: 0; transition: opacity 0.2s ease;">
              <span id="match-count">0 coincidencia(s)</span>
            </div>
          </div>
        </div>
      </aside>

      <!-- Artículo -->
      <article class="post-article">
        <header class="post-header">
          <a href="/blog" class="back-link hover-link mono" data-cursor-expand>
            cd ..
          </a>
          
          <div class="terminal-log-command mono" style="margin-top: 1rem; color: var(--accent-secondary);">
            <span style="color: var(--accent-primary);">$</span> cat journal/{post.id}.md
          </div>
          
          <div class="post-meta mono">
            <span>// PUBLISHED_ON:</span>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              }).toUpperCase()}
            </time>
          </div>

          <h1 class="post-title">{post.data.title}</h1>
          
          <div class="post-tags">
            {post.data.tags.map(tag => (
              <span class="post-tag mono">tag::{tag}</span>
            ))}
          </div>
          
          {post.data.image && (
            <div class="post-image-wrapper">
              <img src={post.data.image} alt={post.data.title} class="post-hero-image" />
            </div>
          )}
        </header>

        <div class="post-content">
          <Content />
        </div>
      </article>
    </div>
  </div>

  <!-- Botón Flotante de Navegación (Categorías + Búsqueda) -->
  <button
    id="post-nav-btn"
    class="post-nav-btn mono"
    aria-label="Navegación y búsqueda"
    data-cursor-expand
  >
    <svg
      viewBox="0 0 24 24"
      width="18"
      height="18"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <span>nav_search()</span>
  </button>

  <!-- Modal de Navegación (Categorías + Búsqueda) -->
  <div id="post-nav-modal" class="post-nav-modal">
    <div class="post-nav-backdrop" id="post-nav-backdrop"></div>
    <div class="post-nav-content">
      <div class="post-nav-header">
        <span class="modal-title mono">// POST_NAVIGATION</span>
        <button
          id="close-post-nav-modal"
          class="close-modal-btn mono"
          aria-label="Cerrar"
        >[x]</button>
      </div>
      <div class="post-nav-body">
        <!-- Bloque de Búsqueda -->
        <div class="modal-search-block">
          <div class="terminal-cmd mono" style="margin-bottom: 0.75rem; font-size: 0.75rem; color: var(--accent-secondary);">
            $ grep -in <span class="syntax-keyword">"term"</span> post.md
          </div>
          <div class="search-input-wrapper" style="margin-bottom: 0;">
            <span class="prompt">$</span>
            <input type="text" id="modal-grep-input" class="grep-input" placeholder="buscar texto..." autocomplete="off" data-cursor-expand />
          </div>
          <div id="modal-search-stats" class="search-stats" style="display: none; opacity: 0; transition: opacity 0.2s ease;">
            <span id="modal-match-count">0 coincidencia(s)</span>
          </div>
        </div>

        <hr class="post-nav-divider" />

        <!-- Bloque de Categorías -->
        <div class="terminal-cmd mono" style="margin-bottom: 0.75rem; font-size: 0.75rem; color: var(--accent-secondary);">
          $ ls -F content/blog/
        </div>
        <ul class="modal-category-list mono">
          <li>
            <a href="/blog?category=all" class="modal-category-btn hover-link" data-cursor-expand>
              <span class="btn-indicator">[ ]</span> todos/ ({totalPostsCount})
            </a>
          </li>
          {categoriesList.map((cat) => {
            const isActive = post.data.category === cat.name;
            return (
              <li>
                <a href={`/blog?category=${cat.name}`} class={`modal-category-btn hover-link ${isActive ? 'active' : ''}`} data-cursor-expand>
                  <span class="btn-indicator">{isActive ? '[*]' : '[ ]'}</span> {cat.name.toLowerCase()}/ ({cat.count})
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </div>
</Layout>



<script>
  function setupPostNavModal() {
    const btn = document.getElementById('post-nav-btn');
    const modal = document.getElementById('post-nav-modal');
    const backdrop = document.getElementById('post-nav-backdrop');
    const closeBtn = document.getElementById('close-post-nav-modal');

    if (!btn || !modal) return;

    const openModal = () => {
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };

    btn.addEventListener('click', openModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (backdrop) backdrop.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });
  }

  function setupScrollProgress() {
    const scrollBar = document.getElementById('scroll-bar');
    if (!scrollBar) return;

    window.addEventListener('scroll', () => {
      const windowScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (windowScroll / height) * 100;
      scrollBar.style.width = scrolled + '%';
    });
  }

  function setupSearch() {
    const postContent = document.querySelector('.post-content');
    if (!postContent) return;

    let originalHTML = postContent.innerHTML;

    function escapeRegExp(string: string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function performSearch(query: string, statsEl: HTMLElement | null, countEl: HTMLElement | null) {
      postContent.innerHTML = originalHTML;

      if (!query || query.trim().length < 2) {
        if (statsEl) {
          statsEl.style.opacity = '0';
          setTimeout(() => { statsEl.style.display = 'none'; }, 200);
        }
        return;
      }

      const escapedQuery = escapeRegExp(query);
      const regex = new RegExp(`(${escapedQuery})`, 'gi');
      let matches = 0;

      const walk = document.createTreeWalker(postContent, NodeFilter.SHOW_TEXT, null);
      const textNodes: Node[] = [];
      let currentNode;

      while (currentNode = walk.nextNode()) {
        const parentTag = currentNode.parentElement?.tagName.toUpperCase();
        if (parentTag === 'PRE' || parentTag === 'CODE' || parentTag === 'SCRIPT' || parentTag === 'STYLE' || parentTag === 'MARK') continue;
        if (regex.test(currentNode.nodeValue || '')) textNodes.push(currentNode);
      }

      textNodes.forEach(node => {
        const text = node.nodeValue || '';
        const nodeMatches = text.match(regex);
        if (nodeMatches) matches += nodeMatches.length;
        const span = document.createElement('span');
        span.innerHTML = text.replace(regex, '<mark class="highlight">$1</mark>');
        node.parentNode?.replaceChild(span, node);
      });

      if (statsEl && countEl) {
        statsEl.style.display = 'block';
        statsEl.offsetHeight;
        statsEl.style.opacity = '1';
        countEl.textContent = `${matches} coincidencia${matches === 1 ? '' : 's'}`;
      }
    }

    // Sidebar input
    const grepInput = document.getElementById('grep-input');
    const searchStats = document.getElementById('search-stats');
    const matchCount = document.getElementById('match-count');
    if (grepInput) {
      grepInput.addEventListener('input', () => performSearch(grepInput.value, searchStats, matchCount));
    }

    // Modal input
    const modalInput = document.getElementById('modal-grep-input');
    const modalStats = document.getElementById('modal-search-stats');
    const modalCount = document.getElementById('modal-match-count');
    if (modalInput) {
      modalInput.addEventListener('input', () => performSearch(modalInput.value, modalStats, modalCount));
    }

    document.addEventListener('astro:before-swap', () => {
      if (postContent && originalHTML) postContent.innerHTML = originalHTML;
    }, { once: true });
  }

  function setupCopyButtons() {
    const pres = document.querySelectorAll('.post-content pre');
    pres.forEach(pre => {
      if (pre.querySelector('.copy-btn')) return;

      const btn = document.createElement('button');
      btn.className = 'copy-btn mono';
      btn.textContent = '[copy]';

      btn.addEventListener('click', async () => {
        const text = pre.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = '[copied!]';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = '[copy]';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = '[error]';
          setTimeout(() => {
            btn.textContent = '[copy]';
          }, 2000);
        }
      });

      pre.appendChild(btn);
    });
  }

  document.addEventListener('astro:page-load', () => {
    setupPostNavModal();
    setupScrollProgress();
    setupSearch();
    setupCopyButtons();
  });
</script>
