---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sortedProjects = projects.sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<Layout
  title="Proyectos & Arquitectura — hadercode.dev"
  description="Galería de proyectos de desarrollo frontend, optimización de performance y soluciones de software a medida."
>
  <div class="projects-page-wrapper">
    <!-- Background Large Text -->
    <div class="bg-giant-text">BUILDS</div>

    <section class="projects-intro">
      <div class="section-header-code">
        <span class="syntax-keyword">const</span>
        <span class="syntax-fn">projectGallery</span> = <span
          class="syntax-keyword">await</span
        > loadAllProjects();
      </div>
      <h1 class="intro-title">Proyectos & Construcciones</h1>
      <p class="intro-desc">
        Compilación de sistemas interactivos y soluciones de software que he
        desarrollado. Cada proyecto prioriza la robustez de la arquitectura web,
        tiempos de carga mínimos y una experiencia de usuario sumamente cuidada.
      </p>
      <div class="scroll-helper mono">
        <span class="arrow-indicator">&larr;</span> Desliza horizontalmente para navegar
        por el grid <span class="arrow-indicator">&rarr;</span>
      </div>
    </section>

    <!-- Horizontal Showcase Container -->
    <section class="showcase-section">
      <div class="horizontal-scroll-container" id="horizontal-scroll">
        {
          sortedProjects.map((project, index) => (
            <div class="showcase-item">
              <span class="item-number mono">
                ({String(index + 1).padStart(2, "0")})
              </span>
              <div class="item-inner">
                <a
                  href={project.data.link}
                  class="item-link hover-link"
                  data-cursor-expand
                >
                  <div class="item-image-wrapper">
                    <img
                      src={project.data.image}
                      alt={project.data.title}
                      class="item-image"
                    />
                    <div class="item-image-overlay" />
                  </div>
                  <div class="item-info">
                    <div class="item-tags">
                      {project.data.tags.map((tag) => (
                        <span class="item-tag mono">tech::{tag}</span>
                      ))}
                    </div>
                    <h2 class="item-title">{project.data.title}</h2>
                    <p class="item-desc">{project.data.description}</p>
                  </div>
                </a>
              </div>
            </div>
          ))
        }

        <!-- Tarjeta final de CTA de contacto en el mismo scroll horizontal -->
        <div class="showcase-item cta-item">
          <div class="item-inner cta-inner">
            <span class="cta-subtitle mono">// NEW_PROJECT_REQUEST</span>
            <h2 class="cta-title">¿Compilamos algo juntos?</h2>
            <p class="cta-desc">
              Hagamos realidad tu idea con arquitectura web óptima y el máximo
              rendimiento posible.
            </p>
            <a href="/contact" class="btn-magnetic" data-cursor-expand>
              <span>./start_collaboration.sh</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .projects-page-wrapper {
    position: relative;
    padding-top: 10rem;
    min-height: 100vh;
    overflow: hidden;
  }

  /* Giant decorative text in background */
  .bg-giant-text {
    position: absolute;
    top: 25%;
    left: 5%;
    font-family: var(--font-display);
    font-size: 15vw;
    font-weight: 800;
    line-height: 1;
    color: rgba(255, 255, 255, 0.015);
    pointer-events: none;
    user-select: none;
    text-transform: uppercase;
    z-index: 0;
    white-space: nowrap;
  }

  .projects-intro {
    max-width: 800px;
    margin-bottom: 4rem;
    position: relative;
    z-index: 1;
  }

  .intro-title {
    font-size: clamp(3rem, 6vw, 5rem);
    text-transform: uppercase;
    line-height: 1;
    margin-top: 0.5rem;
  }

  .intro-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: 1.5rem;
  }

  .scroll-helper {
    margin-top: 2.5rem;
    font-size: 0.85rem;
    color: var(--accent-secondary);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .arrow-indicator {
    animation: bounceLR 1.5s infinite ease-in-out;
  }

  .arrow-indicator:first-child {
    animation-delay: 0.75s;
  }

  @keyframes bounceLR {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(5px);
    }
  }

  /* Horizontal Showcase */
  .showcase-section {
    position: relative;
    z-index: 1;
    width: 100vw;
    margin-left: -2rem;
  }

  .horizontal-scroll-container {
    display: flex;
    gap: 4rem;
    overflow-x: auto;
    padding: 2rem 4rem 6rem 4rem;
    scrollbar-width: none;
  }

  .horizontal-scroll-container::-webkit-scrollbar {
    display: none;
  }

  .showcase-item {
    flex: 0 0 550px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .item-number {
    font-size: 1.1rem;
    color: var(--accent-primary);
    font-weight: 700;
  }

  .item-inner {
    background-color: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 12px; /* Reducción de redondeado para estética técnica */
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .item-inner:hover {
    border-color: rgba(212, 255, 63, 0.15);
    box-shadow: 0 20px 40px -20px rgba(212, 255, 63, 0.05);
  }

  .item-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition:
      transform 0.8s var(--ease-out-expo),
      filter 0.8s var(--ease-out-expo);
  }

  .item-inner:hover .item-image {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  .item-image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(13, 13, 12, 0.8)
    );
  }

  .item-info {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .item-tags {
    display: flex;
    gap: 0.5rem;
  }

  .item-tag {
    font-size: 0.75rem;
    color: var(--accent-secondary);
    background-color: rgba(255, 255, 255, 0.03);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.02);
  }

  .item-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .item-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* CTA Item Styles */
  .cta-item {
    flex: 0 0 450px;
  }

  .cta-inner {
    padding: 4rem 3rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    background: linear-gradient(
      135deg,
      var(--bg-secondary) 0%,
      rgba(212, 255, 63, 0.02) 100%
    );
    border: 1px solid rgba(212, 255, 63, 0.05);
    border-radius: 12px;
  }

  .cta-subtitle {
    font-size: 0.85rem;
    color: var(--accent-primary);
    letter-spacing: 0.1em;
  }

  .cta-title {
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .cta-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .cta-inner .btn-magnetic {
    align-self: flex-start;
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .showcase-section {
      width: auto;
      margin-left: 0;
    }

    .horizontal-scroll-container {
      flex-direction: column;
      gap: 3rem;
      padding: 0;
      overflow-x: visible;
    }

    .showcase-item {
      flex: 1 1 auto;
      width: 100%;
    }

    .scroll-helper {
      display: none;
    }

    .bg-giant-text {
      display: none;
    }
  }
</style>

<script>
  function setupHorizontalScroll() {
    const container = document.getElementById("horizontal-scroll");
    if (!container) return;

    if (window.matchMedia("(min-width: 769px)").matches) {
      container.addEventListener(
        "wheel",
        (e) => {
          if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
            e.preventDefault();
            container.scrollLeft += e.deltaY;
          }
        },
        { passive: false },
      );
    }
  }

  document.addEventListener("astro:page-load", setupHorizontalScroll);
</script>
